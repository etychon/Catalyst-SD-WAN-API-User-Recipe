# Copy this file to .env in the samples/ directory (never commit .env). Use a secrets manager in production.

# Base URL of Cisco Catalyst SD-WAN Manager (no trailing slash), e.g. https://manager.example.com:8443
SDWAN_BASE_URL=https://sdwan-manager.example.com:8443
# Legacy alias (optional): if SDWAN_BASE_URL is unset, SDWAN_MANAGER is used instead
# SDWAN_MANAGER=https://sdwan-manager.example.com:8443

# Preferred for 20.18+: JWT login (POST /jwt/login)
SDWAN_USERNAME=
SDWAN_PASSWORD=
# Optional: use an existing access token instead of /jwt/login (jwt or auto only; not session).
# For POST/PUT/PATCH/DELETE, set SDWAN_JWT_CSRF from the same /jwt/login JSON "csrf" field when present.
# If "csrf" was missing from that JSON, ManagerClient will try GET /dataservice/client/token with Bearer after login.
# Optional SDWAN_JWT_REFRESH enables POST /jwt/refresh on 401 (same JSON "refresh" field).
# SDWAN_JWT_TOKEN=
# SDWAN_JWT_CSRF=
# SDWAN_JWT_REFRESH=

# Optional: prompt for password instead of storing it (supported by collect_dashboard_snapshot.py)
# SDWAN_PASSWORD_PROMPT=1

# Optional: access token duration in seconds (1–604800 per DevNet)
SDWAN_JWT_DURATION=1800

# Authentication mode: jwt | session | auto (try JWT, then session)
SDWAN_AUTH_MODE=jwt

# TLS: leave true in production; lab-only may set false (not recommended)
SDWAN_VERIFY_SSL=true

# Optional multi-tenant (see docs/multitenant-clusters.md and docs/recipes/multitenant-connectivity.md)
# SDWAN_TENANT=                    # JWT only: optional "tenant" string in POST /jwt/login body (tenant-scoped users)
# SDWAN_TENANT_SUBDOMAIN=          # Session only + provider: tenant subDomain; client fetches VSessionId automatically
# SDWAN_VSESSION_ID=               # Optional: send header VSessionId on every call (JWT or session) when you already have it

# Optional: multi-cluster inventory merge (JSON array for scripts/federation_demo.py)
# SDWAN_FEDERATION=[{"cluster_id":"west","base_url":"https://vm1:8443"}]

# Optional: HTTP timeouts
# SDWAN_CONNECT_TIMEOUT=30
# SDWAN_READ_TIMEOUT=120

# Optional: statistics query device rule "field" for cellular_signal_history.py (EIOLTE uniqueAggregation).
# Default in script is vdevice_name (per GET /dataservice/statistics/eiolte/query/fields on 20.18).
# SDWAN_STATS_DEVICE_FIELD=vdevice_name
