# Copy into your shell or secret manager. Do not commit real credentials.
# This file mirrors the incorporated starter pack; this repo prefers SDWAN_BASE_URL.

export SDWAN_BASE_URL=https://sdwan-manager.example.com:8443
# Or use legacy name:
# export SDWAN_MANAGER=https://sdwan-manager.example.com

export SDWAN_USERNAME=api-readonly-service
export SDWAN_PASSWORD_PROMPT=1
# Optional:
# export SDWAN_AUTH_MODE=auto
# export SDWAN_VERIFY_SSL=true
